DATABASE_URI=postgresql://payload:payload@localhost:5433/payload
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Microsoft OAuth (optional - leave empty for email/password bootstrap)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/callback
NEXT_PUBLIC_MICROSOFT_AUTH_ENABLED=

# Cloud media storage (optional - leave empty to use local-disk storage).
# When S3_ENDPOINT is set, the `media` collection is served from an
# S3-compatible bucket (e.g. Supabase Storage) instead of the local filesystem.
# Required on serverless hosts (Vercel) where the filesystem is ephemeral.
# Supabase: Project Settings > Storage > S3 connection.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Production note: on serverless (Vercel), DATABASE_URI MUST use Supabase's
# transaction pooler (port 6543 / Supavisor), not the direct 5432 connection,
# to avoid exhausting connections. Example:
# postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
